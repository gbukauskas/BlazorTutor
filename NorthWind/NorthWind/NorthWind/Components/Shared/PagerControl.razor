@using ClassLibraryDatabase.CustomPager
@using NorthWind.Services
@using System.Text
@using System.Diagnostics

@inject StateSvc StateManager

<div class="pager" name="customer-pager">
    @foreach (var link in PrintableButtons)
    {

        <a class="custom-link @GetClassName(link)" href="#" title="@GetTitle(link)" disabled="@link.IsDisabled"
               @onclick='(() => NavigateLink(link.PageIndex, link.IsDisabled))' @onclick:preventDefault="true" @onclick:stopPropagation="true">
            @GenerateLabel(link)
        </a> 
    }
    <span class="set-info">@Model!.RowCount rec. in @Model!.PageCount pages.</span>

    <EditForm FormName="PagerNavigate" Model="Model" class="form-inline" Enhance OnValidSubmit="NavigateForm">
        <DataAnnotationsValidator />
        <span>Go to page</span>
        <InputText @bind-Value="Model!.PageNumberStr" style="width: 6em;" name="current-page"  />
        <ValidationMessage For="() => Model!.PageNumberStr" />
        <button type="submit" class="btn btn-primary btn-sm" disabled="@Model!.RowCount > 0">Submit</button>

        @if (!String.IsNullOrEmpty(ErrorMessage))
        {
            <span class="text-danger">@DecodeMsg(ErrorMessage)</span>
        }
    </EditForm>
</div>

@code {
    // https://havit.blazor.eu/components/HxPager
    // https://github.com/radzenhq/radzen-blazor/blob/master/Radzen.Blazor/RadzenPager.razor.cs

    // https://learn.microsoft.com/en-us/aspnet/core/blazor/forms/input-components?view=aspnetcore-8.0
    // https://amarozka.dev/blazor-editform-validation/

    [SupplyParameterFromForm]
    public PgPostData? Model { get; set; }

    /// <summary>
    /// Number of pages. Default value is 1.
    /// </summary>
    [Parameter]
    public int MaxButtons { get; set; } = 10;   // TODO:

    /// <summary>
    /// Number of pages. Default value is 1.
    /// </summary>
    [Parameter]
    public int PageCount { get; set; } = 1;

    /// <summary>
    /// Current page. Default value is 1
    /// </summary>
    [Parameter]
    public int PageNumber { get; set; } = 1;

    /// <summary>
    /// Number of rows in the page. Default value is 15
    /// </summary>
    [Parameter]
    public int PageSize { get; set; } = 15;

    /// <summary>
    /// URL encoded error message
    /// </summary>
    [Parameter]
    public string ErrorMessage { get; set; } = "";

    [CascadingParameter(Name = "StateForComponent")] 
    public required StateForComponent currentState { get; set; }

    private List<PgData> PrintableButtons = new List<PgData>();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        Model ??= currentState!.PagerState;
        Debug.Assert(Model != null);

        if (String.IsNullOrEmpty(Model.PageNumberStr))
        {
            Model.PageNumberStr =  Model == null ? "1" : Model.PageNumber.ToString();
        }
        PrintableButtons = PrepareButtonList();
        if (PrintableButtons.Count > 0)
        {
            InsertPrevButtons();
            AppendTrailButtons();
            EnableDisableLinks();
        }
    }

    private string GetClassName(PgData page)
    {
        StringBuilder rzlt = new();
        if (page.IsSelected)
        {
            rzlt.Append("selected-label");
        }
        // if (page.IsDisabled)
        // {
        //     rzlt.Append(" disabled-link");
        // }
        return rzlt.ToString();
    }

    /// <summary>
    /// The returns label string.
    /// </summary>
    /// <param name="page">Current page</param>
    /// <returns>The label</returns>
    private string GenerateLabel(PgData page)
    {
        string rzlt;
        switch (page.PageIndex)
        {
            case "L":
                rzlt = "\u2BEC";    // Go to first
                break;
            case "l":
                rzlt = "\u2B9C";    // Go to previous
                break;
            case "r":
                rzlt = "\u2B9E";    // Go to next
                break;
            case "R":
                rzlt = "\u2BEE";    // Go to last
                break;
            default:
                rzlt = page.PageIndex;  // Go to the page, page.PageIndex is index of the page
                break;
        }
        return rzlt;
    }

    private string DecodeMsg(string message)
    {
        return String.IsNullOrEmpty(message) ? "" : System.Net.WebUtility.UrlDecode(message);
    }

    private string GetTitle(PgData page)
    {
        string rzlt;
        switch (page.PageIndex)
        {
            case "L":
                rzlt = "Go back to first page";    // Go to first
                break;
            case "l":
                rzlt = "Go back one page";      // Go to previous page
                break;
            case "r":
                rzlt = "Go to the next page";    // Go to next page
                break;
            case "R":
                rzlt = "Go to the last page";    // Go to last page
                break;
            default:
                rzlt = $"Go to page # {page.PageIndex}";  // Go to the page, page.PageIndex is index of the page
                break;
        }
        return rzlt;
    }

    /// <summary>
    /// The function collects <code>PagerData</code> structures in the <code>PrintableButtons</code> list.
    /// The collection must be no longer than the value stated in the parameter <code>MaxButtons</code>.
    /// The function shifts to left <code>PrintableButtons</code> if current page (item with <code>PageNumber</code>) is not visible.
    /// </summary>
    private List<PgData> PrepareButtonList()
    {
        Debug.Assert(Model != null);
        bool currentPageIsVisible = false;
        var newPrintableButtons = new List<PgData>();
        for (int i = 1; i <= Model.PageCount; i++)
        {
            if (newPrintableButtons.Count >= Model.MaxButtons)    // Shift to left
            {
                newPrintableButtons = newPrintableButtons.Skip(1).Take(PrintableButtons.Count - 1).ToList();
            }
            var item = new PgData(i, i.ToString()) {
                IsSelected = i == Model.PageNumber,
                IsDisabled = i == Model.PageNumber
            }; // Append next button
            newPrintableButtons.Add(item);
            if (item.IsSelected)
            {
                currentPageIsVisible = true;
            }
            if (currentPageIsVisible && newPrintableButtons.Count() >= Model.MaxButtons)
            {
                break;
            }
        }
        return newPrintableButtons;
    }

    /// <summary>
    /// The function inserts 2 buttons: "Go to previous page" and "Go to first".
    /// </summary>
    private void InsertPrevButtons()
    {
        var item = new PgData(Math.Max(PrintableButtons[0].Id - 1, 1), "l")
        {
            IsSelected = false,
            //            IsDisabled = PrintableButtons[0].PageIndex == "1"
        };
        PrintableButtons.Insert(0, item);
        item = new PgData(1, "L")
        {
            IsSelected = false,
            //            IsDisabled = PrintableButtons[1].PageIndex == "1"
        };
        PrintableButtons.Insert(0, item);
    }

    /// <summary>
    /// The function appends 2 buttons: "Go to next" and "Go to last"
    /// </summary>
    private void AppendTrailButtons()
    {
        int lastItem = PrintableButtons[PrintableButtons.Count - 1].Id;
        var item = new PgData(Math.Min(lastItem + 1, PageCount), "r")
        {
            IsSelected = false,
            //            IsDisabled = lastItem >= PageCount
        };
        PrintableButtons.Add(item);
        item = new PgData(PageCount, "R")
        {
            IsSelected = false,
            //            IsDisabled = lastItem >= PageCount
        };
        PrintableButtons.Add(item);
    }

    private void NavigateLink(string pgIndex, bool isDisabled)
    {
        Debug.Assert(Model != null);
        if (!isDisabled)
        {
            int newPgNumber;
            switch (pgIndex)
            {
                case "L":
                    newPgNumber = 1;
                    break;
                case "l":
                    newPgNumber = Math.Max(Model.PageNumber - 1, 1);
                    break;
                case "r":
                    newPgNumber = Math.Min(Model.PageNumber + 1, Model.PageCount);
                    break;
                case "R":
                    newPgNumber = Model.PageCount;
                    break;
                default:
                    if (!int.TryParse(pgIndex, out newPgNumber))
                    {
                        newPgNumber = 1;
                    }
                    break;
            }
            Model = Model with { PageNumber = newPgNumber };
            EnableDisableLinks();
            StateHasChanged();
            var newState = currentState with { PagerState = Model };
            lock (StateManager._lock)
            {
                StateManager.StateSubject.OnNext((StateForComponent)newState);
            }
        }
    }

    private void EnableDisableLinks()
    {
        Debug.Assert(Model != null);
        PrintableButtons[0].IsDisabled = Model.PageNumber == 1;
        PrintableButtons[1].IsDisabled = Model.PageNumber == 1;
        int lastIndex = PrintableButtons.Count - 1;
        PrintableButtons[lastIndex].IsDisabled = Model.PageNumber == Model.PageCount;
        PrintableButtons[lastIndex - 1].IsDisabled = Model.PageNumber == Model.PageCount;
    }

    private void NavigateForm()
    {
        Debug.Assert(Model != null);
        int oldPageNumber = Model.PageNumber;
        int newPgNumber;
        if (!int.TryParse(Model.PageNumberStr, out newPgNumber))
        {
            newPgNumber = 1;
        }

        if (newPgNumber < 1)
        {
            Model.PageNumber = Model.PageCount;
        }
        else if (newPgNumber > Model.PageCount)
        {
            Model.PageNumber = 1;
        }
        else
        {
            Model.PageNumber = newPgNumber;
        }
        EnableDisableLinks();
        StateHasChanged();
        var newState = currentState with { PagerState = Model };
        lock (StateManager._lock)
        {
            StateManager.StateSubject.OnNext((StateForComponent)newState);
        }
    }

    private string GetDisabled(PgData link)
    {
        return link.IsDisabled ? "disabled" : "";
    }

    // https://stackoverflow.com/questions/68308779/blazor-components-how-to-communicate-from-grandchild-to-child-to-parent-or-gran
}
